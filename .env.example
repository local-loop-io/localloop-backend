# localLOOP Backend Environment Configuration
# Copy to .env and modify values as needed

# IMPORTANT: In production (NODE_ENV=production), you MUST set:
# - DATABASE_URL (with a secure password)
# - MINIO_SECRET_KEY (generate a strong secret)
# - BETTER_AUTH_SECRET (if AUTH_ENABLED=true)
# - API_KEY (if API_KEY_ENABLED=true)
# The application will refuse to start in production with default/missing secrets.

NODE_ENV=development
PORT=8088
PUBLIC_BASE_URL=https://loop-api.urbnia.com
NODE_ID=lab-hub.loop
NODE_NAME=localLOOP Lab Hub
NODE_CAPABILITIES=material-registry,lab-relay

# Postgres
# For development only - use strong passwords in production
POSTGRES_DB=localloop
POSTGRES_USER=localloop
POSTGRES_PASSWORD=localloop_dev_password
DATABASE_URL=postgresql://localloop:localloop_dev_password@postgres:5432/localloop
DATABASE_SSL=false
DB_POOL_SIZE=20
# Connection pool timeouts (milliseconds)
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
# Server-level request timeout (milliseconds)
REQUEST_TIMEOUT_MS=30000

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible)
# For development only - use strong passwords in production
MINIO_ENDPOINT=minio-proxy
MINIO_PORT=9000
MINIO_ACCESS_KEY=localloop
MINIO_SECRET_KEY=localloop_dev_secret
MINIO_BUCKET=localloop-assets
MINIO_USE_SSL=false
MINIO_ROOT_USER=localloop
MINIO_ROOT_PASSWORD=localloop_dev_secret

# API settings
PUBLIC_LIMIT=100
ALLOWED_ORIGINS=https://local-loop-io.github.io
RATE_LIMIT_MAX=60
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_WINDOW=15 minutes
RATE_LIMIT_WRITE_WINDOW=15 minutes
SSE_KEEPALIVE_MS=25000
SSE_MAX_CLIENTS=200
BODY_LIMIT=1048576
RUN_MIGRATIONS=true
SEARCH_REFRESH_ON_WRITE=true

# Auth
# Generate a secure secret for production: openssl rand -hex 32
AUTH_ENABLED=false
AUTH_TRUSTED_ORIGINS=https://local-loop-io.github.io
BETTER_AUTH_SECRET=dev_auth_secret_not_for_production
API_KEY_ENABLED=false
API_KEY=dev_api_key_not_for_production

# Workers
WORKER_ENABLED=false

# Payments
PAYMENTS_ENABLED=false
