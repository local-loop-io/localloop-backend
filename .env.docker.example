PORT=8088
PUBLIC_BASE_URL=https://loop-api.urbnia.com
NODE_ID=lab-hub.loop
NODE_NAME=localLOOP Lab Hub
NODE_CAPABILITIES=material-registry,lab-relay

# Postgres
POSTGRES_DB=localloop
POSTGRES_USER=localloop
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://localloop:change-me@postgres:5432/localloop
DATABASE_SSL=false
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
REQUEST_TIMEOUT_MS=30000

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3-compatible)
MINIO_ENDPOINT=minio-proxy
MINIO_PORT=9000
MINIO_ACCESS_KEY=localloop
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=localloop-assets
MINIO_USE_SSL=false
MINIO_ROOT_USER=localloop
MINIO_ROOT_PASSWORD=change-me

# API settings
PUBLIC_LIMIT=100
ALLOWED_ORIGINS=https://local-loop-io.github.io
RATE_LIMIT_MAX=60
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_WINDOW=15 minutes
RATE_LIMIT_WRITE_WINDOW=15 minutes
SSE_KEEPALIVE_MS=25000
SSE_MAX_CLIENTS=200
BODY_LIMIT=1048576
RUN_MIGRATIONS=true
SEARCH_REFRESH_ON_WRITE=true

# Auth
AUTH_ENABLED=false
AUTH_TRUSTED_ORIGINS=https://local-loop-io.github.io
BETTER_AUTH_SECRET=change-me
API_KEY_ENABLED=false
API_KEY=change-me

# Workers
WORKER_ENABLED=false

# Payments
PAYMENTS_ENABLED=false

# Backup automation (used by deploy/backup.sh or the backup systemd unit)
# BACKUP_ROOT=/opt/localloop-backend/backups
# RETENTION_DAYS=14
